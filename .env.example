# Database URL (required — PostgreSQL connection string from Render / Supabase / etc.)
DATABASE_URL=

# Resend — used for ALL contact forms (booking, laskuri, IT contact) and admin emails
# Get your API key at: https://resend.com/api-keys
# Must be set in your deployment environment (Render / Replit secrets) for email to work
RESEND_API_KEY=
FROM_EMAIL=Puuhapatet <onboarding@resend.dev>

# Admin / contact form recipient — override to change who receives contact form submissions
ADMIN_EMAIL=joonatan@puuhapatet.fi

# ─── Admin authentication (REQUIRED for the admin/data API) ───────────────────
# Secret used to sign admin login tokens. MUST be a long random string and MUST
# be set in production — without it nobody can log in (the API fails closed).
# Generate one e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# One-time password for an admin account that has NEVER set its own password.
# Lets the team log in the first time after the security upgrade; it is hashed
# and stored on first successful login. Set a strong value, share it once, then
# each member sets their own password in Asetukset. Members who already changed
# their password keep using that — this default does not affect them.
ADMIN_DEFAULT_PASSWORD=

# Worker notification emails — comma-separated list, used for quote response notifications
WORKER_EMAILS=joonatan@puuhapatet.fi,matias@puuhapatet.fi

# Worker display names and emails (used in invite emails and worker info lookups)
WORKER_JOONATAN_NAME=Joonatan Juuri
WORKER_JOONATAN_EMAIL=joonatan@puuhapatet.fi
WORKER_MATIAS_NAME=Matias Pitkänen
WORKER_MATIAS_EMAIL=matias@puuhapatet.fi

# Calendar feed token — optional; set to protect /api/calendar.ics from public access
CALENDAR_TOKEN=

# Google Places API — used to fetch real reviews on the reviews section
# Get your API key: https://console.cloud.google.com/apis/credentials
# Enable the "Places API" in your Google Cloud project
GOOGLE_PLACES_API_KEY=

# Your Google Business Profile Place ID
# Find it at: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
# Search for your business name and copy the Place ID (starts with ChIJ...)
GOOGLE_PLACE_ID=

# ─── AI assistant (free model) ───────────────────────────────────────────────
# Powers the public chat bubble + the in-admin assistant. Works with ANY
# OpenAI-compatible endpoint. Without AI_API_KEY the bot still works: it falls
# back to a canned reply and hands off to a human (it never guesses).
#
# Recommended free option — Groq (fast, generous free tier):
#   1. Get a free key at https://console.groq.com/keys
#   2. Set AI_API_KEY below (defaults already target Groq)
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
#
# Other free alternatives (just swap these three values):
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1 + a model ending in ":free"
#   Google Gemini (OpenAI-compat): AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#                                  AI_MODEL=gemini-2.0-flash
#
# ─── Premium model for the IN-ADMIN assistant only (Claude / Anthropic) ──────
# Optional. When set, the internal team assistant ("Avustaja") runs on Claude
# instead of the Groq model above — far better at following instructions (no
# random tool calls) and reading the earnings data correctly. The PUBLIC website
# chat keeps using the free Groq model regardless. Leave blank to keep the whole
# thing on Groq. Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional model override (defaults to Claude Opus 4.8):
ADMIN_AI_MODEL=claude-opus-4-8

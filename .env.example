# Google Places API — used to fetch real reviews on the reviews section
# Get your API key: https://console.cloud.google.com/apis/credentials
# Enable the "Places API" in your Google Cloud project
GOOGLE_PLACES_API_KEY=

# Your Google Business Profile Place ID
# Find it at: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
# Search for your business name and copy the Place ID (starts with ChIJ...)
GOOGLE_PLACE_ID=
